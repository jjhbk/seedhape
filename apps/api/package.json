    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@seedhape/shared": "workspace:*",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.5",
    "drizzle-orm": "^0.38.3",
    "pg": "^8.13.1",
    "bullmq": "^5.37.0",
    "ioredis": "5.9.3",
    "zod": "^3.24.1",
    "nanoid": "^5.0.9",
    "qrcode": "^1.5.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7",
    "@clerk/express": "^1.3.12",
    "@vercel/blob": "^0.27.0",
    "multer": "^1.4.5-lts.1",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@seedhape/typescript-config": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/pg": "^8.11.11",
    "@types/multer": "^1.4.12",
    "@types/qrcode": "^1.5.5",
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
