{
  "name": "@seedhape/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js ",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
