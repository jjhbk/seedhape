# Database
DATABASE_URL=postgresql://seedhape:seedhape_dev_password@localhost:5432/seedhape

# Redis
REDIS_URL=redis://:seedhape_redis_password@localhost:6379

# Clerk Auth
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# API
API_PORT=3001
API_BASE_URL=http://localhost:3001
NODE_ENV=development

# JWT / Security
JWT_SECRET=change_me_in_production_min_32_chars

# Webhooks
WEBHOOK_SIGNING_SECRET=change_me_in_production

# File Storage (Vercel Blob)
# Get from: Vercel dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# OCR (Google Vision or Claude)
GOOGLE_VISION_API_KEY=
ANTHROPIC_API_KEY=

# Next.js Web App
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_API_URL=http://localhost:3001

# Mobile App — edit apps/mobile/src/config.ts directly (no .env for RN)

# Monitoring
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
