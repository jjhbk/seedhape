{
  "name": "@seedhape/shared",
  "version": "0.0.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.1",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@seedhape/typescript-config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
