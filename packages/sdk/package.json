{
  "name": "@seedhape/sdk",
  "version": "0.2.1",
  "description": "SeedhaPe JavaScript SDK — drop-in UPI payment integration",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@seedhape/shared": "workspace:*"
  },
  "devDependencies": {
    "@seedhape/typescript-config": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  }
}
