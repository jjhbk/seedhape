  },
  "dependencies": {
    "@seedhape/sdk": "workspace:*"
  },
  "devDependencies": {
    "@seedhape/typescript-config": "workspace:*",
    "@types/react": "^19.0.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  }
}
