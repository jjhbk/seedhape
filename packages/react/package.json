{
  "name": "@seedhape/react",
  "version": "0.3.13",
  "description": "SeedhaPe React components — PaymentButton, PaymentModal, usePayment hook",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
